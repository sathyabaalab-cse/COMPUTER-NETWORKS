int hexToDecimal(char ch)
{
    if(ch >= '0' && ch <= '9')
        return ch - '0';
    if(ch >= 'A' && ch <= 'F')
        return ch - 'A' + 10;
    if(ch >= 'a' && ch <= 'f')
        return ch - 'a' + 10;
    return 0;
}
void ipToBinary(int ip[], char binary[])
{
    int i;
    char temp[9];
    binary[0] = '\0';
    for(i = 0; i < 4; i++)
    {
        decimalToBinary(ip[i], 8, temp);
        strcat(binary, temp);
    }
}
void macToBinary(char mac[], char binary[])
{
    int i;
    int value;
    char temp[9];
    binary[0]='\0';
    for(i = 0; mac[i] != '\0'; i++)
    {
        if(mac[i] == ':')
            continue;
        value = hexToDecimal(mac[i]) * 16;
        value = value + hexToDecimal(mac[i+1]);
        decimalToBinary(value,8,temp);
        strcat(binary,temp);
        i++;
    }
}
void byteStuffing(char input[], char output[])
{
    int i=0, j = 0;
    printf("\nInput = %s\n", input);
    printf("Input Length = %d\n", strlen(input));
    for(i = 0; input[i] != '\0'; i += 8)
    {
        if(strncmp(&input[i], "01111110", 8) == 0)
        {
            printf("\n--------------------------------");
            printf("\nByte Stuffing Performed");
            printf("\nFlag Byte Found");
            printf("\nEscape Byte Inserted");
            printf("\nOriginal : 01111110");
            printf("\nStuffed  : 01111101 01111110");
            printf("\n--------------------------------");

            memcpy(&output[j], "0111110101111110", 16);
            j += 16;
        }
        else if(strncmp(&input[i], "01111101", 8) == 0)
        {
            printf("\n--------------------------------");
            printf("\nByte Stuffing Performed");
            printf("\nEscape Byte Found");
            printf("\nEscape Byte Inserted");
            printf("\nOriginal : 01111101");
            printf("\nStuffed  : 01111101 01111101");
            printf("\n--------------------------------");

            memcpy(&output[j], "0111110101111101", 16);
            j += 16;
        }
        else
        {
            memcpy(&output[j], &input[i], 8);
            j += 8;
        }
    }

    output[j] = '\0';
}
void bitStuffing(char input[], char output[])
{
    int i=0, j = 0;
    int count = 0;

    for(i = 0; input[i] != '\0'; i++)
    {
        output[j++] = input[i];

        if(input[i] == '1')
        {
            count++;

            if(count == 5)
            {
                printf("\n--------------------------------");
                printf("\nBit Stuffing Performed");
                printf("\nFive Consecutive 1's Found");
                printf("\nBit Position : %d", i + 1);
                printf("\nStuffed Bit Inserted : 0");
                printf("\n--------------------------------");

                output[j++] = '0';
                count = 0;
            }
        }
        else
        {
            count = 0;
        }
    }

    output[j] = '\0';
}
void bitDestuff(char input[], char output[])
{
    int i=0, j = 0;
    int count = 0;

    while(input[i] != '\0')
    {
        output[j++] = input[i];

        if(input[i] == '1')
        {
            count++;
           

            if(count == 5)
            {
                printf("\n--------------------------------");
                printf("\nBit Destuffing Performed");
                printf("\nFive Consecutive 1's Found");
                printf("\nStuffed Bit Removed : 0");
                printf("\nBit Position : %d", i + 2);
                printf("\n--------------------------------");

                i++;        // Skip stuffed 0
                count = 0;
            }
        }
        else
        {
            count = 0;
        }

        i++;
    }

    output[j] = '\0';
}
void byteDestuff(char input[], char output[])
{
    int i=0, j = 0;

    while(input[i] != '\0')
    {
        if(strncmp(&input[i], "0111110101111110", 16) == 0)
        {
            printf("\n--------------------------------");
            printf("\nByte Destuffing Performed");
            printf("\nEscape Byte Removed");
            printf("\nRecovered : 01111110");
            printf("\n--------------------------------");

            memcpy(&output[j], "01111110", 8);
            j += 8;
            i += 16;
        }
        else if(strncmp(&input[i], "0111110101111101", 16) == 0)
        {
            printf("\n--------------------------------");
            printf("\nByte Destuffing Performed");
            printf("\nEscape Byte Removed");
            printf("\nRecovered : 01111101");
            printf("\n--------------------------------");

            memcpy(&output[j], "01111101", 8);
            j += 8;
            i += 16;
        }
        else
        {
            memcpy(&output[j], &input[i], 8);
            j += 8;
            i += 8;
        }
    }

    output[j] = '\0';
}
void removePPPFlag(char input[], char output[])
{
    int len = strlen(input);

    strncpy(output, input + 8, len - 16);
    output[len - 16] = '\0';
}
char binaryToChar(char bits[])
{
    int value=0;

    for(int i=0;i<8;i++)
        value=value*2+(bits[i]-'0');

    return (char)value;
}
void printOriginalMessage(char frame[])
{
    int len = strlen(frame);
    int start = len - 16;      // Last 16 bits = Data(8) + Trailer(8)
    char byte[9];
    int i;

    if(start < 0)
        return;

    for(i=0;i<8;i++)
        byte[i] = frame[start+i];

    byte[8] = '\0';

    int value = 0;

    for(i=0;i<8;i++)
        value = value*2 + (byte[i]-'0');

    printf("%c\n", value);
}
