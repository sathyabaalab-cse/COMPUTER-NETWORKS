void networkLayer(int sourceIndex, int destinationIndex)
{
    int i;
    int j;
    char sourceIPBinary[33];
    char destinationIPBinary[33];
    ipToBinary(table[sourceIndex].ip, sourceIPBinary);
    ipToBinary(table[destinationIndex].ip, destinationIPBinary);

    totalPackets = 0;

    printf("\n          NETWORK LAYER");

    for(i = 0; i < totalBits; i += PACKETSIZE)
    {
        for(j = 0; j < PACKETSIZE; j++)
        {
            if(i + j < totalBits)
                packets[totalPackets][j] = bitStream[i + j];
            else
                packets[totalPackets][j] = '0';
        }

        packets[totalPackets][PACKETSIZE] = '\0';

        printf("\nPacket %d\n", totalPackets + 1);

        printf("Source IP Binary      : %s\n",
               sourceIPBinary);

        printf("Destination IP Binary : %s\n",
               destinationIPBinary);

        printf("Packet Data           : %s\n",
               packets[totalPackets]);

        totalPackets++;
    }

    printf("\nTotal Packets = %d\n",
           totalPackets);
}
void dataLinkLayer(int sourceIndex,
                   int destinationIndex)
{
    int i;
    int frameNo = 0;

    char sourceMACBinary[49];
    char destinationMACBinary[49];

    char trailer[] = "00000000";

    char sourceIPBinary[33];
    char destinationIPBinary[33];

    char sourcePortBinary[17];
    char destinationPortBinary[17];

    char completeFrame[300];
    char stuffedFrame[500];
    char destuffedFrame[500];
   

    char byteStuffedFrame[700];
    char byteDestuffedFrame[700];
    char bitPPPFrame[800];
    char bytePPPFrame[800];
    char noFlagFrame[700];
    macToBinary(table[sourceIndex].mac,
                sourceMACBinary);

    macToBinary(table[destinationIndex].mac,
                destinationMACBinary);

    ipToBinary(table[sourceIndex].ip,
           sourceIPBinary);

    ipToBinary(table[destinationIndex].ip,
           destinationIPBinary);

    portToBinary(sourcePort,
             sourcePortBinary);

    portToBinary(destinationPort,
             destinationPortBinary);

    totalFrames = 0;
    printf("\n         DATA LINK LAYER");
    for(i = 0; i < totalPackets; i++)
    {
        strncpy(frames[frameNo],
                packets[i],
                8);

        frames[frameNo][8] = '\0';

        printf("\nFrame %d\n",
               frameNo + 1);

        printf("Source MAC Binary      : %s\n",
               sourceMACBinary);

        printf("Destination MAC Binary : %s\n",
               destinationMACBinary);

        printf("Data                  : %s\n",
               frames[frameNo]);

        printf("Trailer               : %s\n",
               trailer);

        frameNo++;
        totalFrames++;

        strncpy(frames[frameNo],
                packets[i] + 8,
                8);

        frames[frameNo][8] = '\0';

        printf("\nFrame %d\n",
               frameNo + 1);

        printf("Source MAC Binary      : %s\n",
               sourceMACBinary);


        printf("Destination MAC Binary : %s\n",
               destinationMACBinary);

        printf("Data                  : %s\n",
               frames[frameNo]);


        printf("Trailer               : %s\n",
               trailer);

        frameNo++;
        totalFrames++;
    }
    printf("\nFRAME TRANSMISSION");
    char recoveredMessage[100];
    int msgIndex=0;

    for(i = 0; i < totalFrames; i++)
    {
        completeFrame[0] = '\0';
        char stuffedData[50];
        char recoveredData[50];

        strcat(completeFrame, sourceMACBinary);
        strcat(completeFrame, destinationMACBinary);

        strcat(completeFrame, sourceIPBinary);
        strcat(completeFrame, destinationIPBinary);

        strcat(completeFrame, sourcePortBinary);
        strcat(completeFrame, destinationPortBinary);

        strcat(completeFrame, frames[i]);

        strcat(completeFrame, trailer);

        printf("\nOriginal Frame %d\n", i + 1);
        print8Bits( completeFrame);

/* Bit Stuffing */
        bitStuffing(completeFrame, stuffedFrame);

        printf("\nBit Stuffed Frame\n");
        print8Bits(stuffedFrame);
        /* Byte Stuffing */
       byteStuffing(completeFrame, byteStuffedFrame);
       printf("\nLength = %d", strlen(stuffedData));
       printf("\nStuffedData = %s\n", stuffedData);

       printf("\nOriginal Data \n");
       print8Bits(completeFrame);

       printf("\nByte Stuffed Data\n ");
       print8Bits(byteStuffedFrame);
        char bitPPPFrame[800];
        char bytePPPFrame[800];
     

/* BIT PPP */
        strcpy(bitPPPFrame,"01111110");
        strcat(bitPPPFrame,stuffedFrame);
        strcat(bitPPPFrame,"01111110");

        printf("\nBIT  Frame Format\n");
        print8Bits(bitPPPFrame);

        printf("\nBIT RECEIVER SIDE\n");

        removePPPFlag(bitPPPFrame,noFlagFrame);

        printf("\nPPP Flag Removed\n");
        print8Bits(noFlagFrame);

        bitDestuff(noFlagFrame,destuffedFrame);

        printf("\nBit Destuffed Frame\n");
        print8Bits(destuffedFrame);
       
        

/* BYTE PPP */
        strcpy(bytePPPFrame,"01111110");
        strcat(bytePPPFrame,byteStuffedFrame);
        strcat(bytePPPFrame,"01111110");

        printf("\nBYTE PPP Frame\n");
        print8Bits(bytePPPFrame);

        printf("\nBYTE RECEIVER SIDE\n");

        removePPPFlag(bytePPPFrame,noFlagFrame);
        printf("\nPPP Flag Removed\n");
        print8Bits(noFlagFrame);

        byteDestuff(noFlagFrame, byteDestuffedFrame);

        printf("\nByte Destuffed Frame\n");
        print8Bits(byteDestuffedFrame);
        

        
        
        char recoveredByte[9];

        int len = strlen(byteDestuffedFrame);

        strncpy(recoveredByte,
        &byteDestuffedFrame[len-16],
        8);


        recoveredByte[8] = '\0';

        printf("\nRecovered Byte Data : %s\n", recoveredByte);
        printf("Recovered Byte Message : %c\n", binaryToChar(recoveredByte));

        recoveredMessage[msgIndex++] = binaryToChar(recoveredByte);
       
    }
    recoveredMessage[msgIndex]='\0';

    printf("\nRecovered Original Message : %s\n", recoveredMessage);
    printf("\nTotal Frames = %d\n",
           totalFrames);
}
